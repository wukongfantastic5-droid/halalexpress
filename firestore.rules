rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // =========================
    // USERS
    // =========================
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // =========================
    // RIDERS
    // =========================
    match /riders/{riderId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == riderId || isAdmin());
    }

    // =========================
    // ORDERS
    // =========================
    match /orders/{orderId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.user_uid == request.auth.uid
                    && (request.resource.data.status == "pending"
                        || request.resource.data.status == "menunggu_pembayaran");
      allow update: if request.auth != null && (
        // admin can update anything
        isAdmin()
        ||
        // rider can update non-delivered orders
        (resource.data.status != "delivered")
        ||
        // customer can edit their own pending orders
        (request.resource.data.user_uid == request.auth.uid
         && resource.data.status == "pending")
      );
      allow delete: if request.auth != null && (
        // admin can delete anything
        isAdmin()
        ||
        // customer can cancel their own pending order
        (request.auth.uid == resource.data.user_uid
         && resource.data.status == "pending")
      );
    }

    // =========================
    // RIDER BANK CHANGE REQUESTS
    // =========================
    match /rider_bank_requests/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.rider_id || isAdmin());
      allow create: if request.auth != null && request.resource.data.rider_id == request.auth.uid;
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }

    // =========================
    // WITHDRAW REQUESTS
    // =========================
    match /withdraw_requests/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.rider_id || isAdmin());
      allow create: if request.auth != null && request.resource.data.rider_id == request.auth.uid;
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }

    // =========================
    // SETTINGS (read before login for maintenance check)
    // =========================
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // =========================
    // ANNOUNCEMENTS
    // =========================
    match /announcements/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // =========================
    // FEEDBACK
    // =========================
    match /feedback/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // =========================
    // TOP-UP REQUESTS
    // =========================
    match /topup_requests/{docId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.uid || isAdmin());
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow write: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && isAdmin();
    }
  }
}
